# Posts.sol — deploy with contracts/script/Deploy.s.sol (see contracts/README.md)
VITE_POSTS_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Interactions.sol — same deploy script (likes / comments by on-chain post id)
VITE_INTERACTIONS_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# SocialGraph.sol — same deploy script (follow / unfollow)
VITE_SOCIAL_GRAPH_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Hasura (Envio indexer)
# Dev + proxy (simplest): leave VITE_HASURA_GRAPHQL_URL unset and point the proxy at your indexer:
# INDEXER_HASURA_URL=http://YOUR_EC2_PUBLIC_IP:8080
# Optional if Hasura needs admin header (same secret as on the server / Envio defaults):
# VITE_HASURA_ADMIN_SECRET=testing
#
# Or bypass proxy (browser calls Hasura directly — needs CORS allowed on Hasura):
# VITE_HASURA_GRAPHQL_URL=http://127.0.0.1:8080/v1/graphql

# Pinata (IPFS photos). API Keys -> New Key -> JWT with pin / file upload.
# VITE_PINATA_JWT=
# VITE_IPFS_GATEWAY_URL=https://gateway.pinata.cloud/ipfs/

# Optional: RPC for reads in the browser (default: public testnet RPC)
# VITE_MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# --- Vercel / produção ---
# O site na Vercel é HTTPS: o GraphQL também tem de ser HTTPS (senão o browser bloqueia).
# VITE_HASURA_GRAPHQL_URL=https://hasura.teu-dominio.com/v1/graphql
# VITE_HASURA_ADMIN_SECRET=...  # se precisares (lembra: fica público no bundle)

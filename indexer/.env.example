# Copiar para .env na mesma pasta (indexer/) e preencher após deploy na Monad testnet.
# forge script script/Deploy.s.sol --rpc-url https://testnet-rpc.monad.xyz --broadcast
#
# Endereços: saída do script (Posts, Interactions, SocialGraph — pela ordem do deploy).

ENVIO_POSTS_ADDRESS=0x0000000000000000000000000000000000000000
ENVIO_INTERACTIONS_ADDRESS=0x0000000000000000000000000000000000000000
ENVIO_SOCIAL_GRAPH_ADDRESS=0x0000000000000000000000000000000000000000

# Bloco em que o deploy foi incluído (explorador ou cast receipt <tx_hash>).
# Deixa comentado ou 0 só para testes; em produção define o bloco real.
ENVIO_START_BLOCK=0
